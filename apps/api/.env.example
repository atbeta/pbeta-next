# App
NODE_ENV=development
PORT=3001

# Database (local: docker-compose, prod: Neon)
DATABASE_URL="postgresql://pbeta:pbeta_dev@localhost:5432/pbeta?schema=public"

# Redis (local: docker-compose, prod: Upstash)
REDIS_URL="redis://localhost:6379"

# CORS allowlist for production (comma-separated origins)
# Example: CORS_ORIGIN="https://pbeta.me,https://pbeta-web-production.up.railway.app"
CORS_ORIGIN="http://localhost:3000"

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# API Keys (for private routes)
API_KEY="change-me-in-production"
